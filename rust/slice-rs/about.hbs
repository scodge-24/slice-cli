<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8" />
  <title>Third-party licenses — slice</title>
  <style>
    body { font-family: system-ui, sans-serif; max-width: 48rem; margin: 2rem auto; padding: 0 1rem; }
    h2 { margin-top: 2rem; border-bottom: 1px solid #ddd; padding-bottom: .25rem; }
    .used-by { color: #555; font-size: .9rem; }
    pre { background: #f6f8fa; padding: 1rem; overflow-x: auto; white-space: pre-wrap; }
  </style>
</head>
<body>
  <h1>Third-party licenses</h1>
  <p>The <code>slice</code> binary statically links the Rust crates below. Their
  license texts are reproduced here to satisfy attribution requirements.</p>
  {{#each licenses}}
  <h2>{{name}}</h2>
  <p class="used-by">Used by:
    {{#each used_by}}<a href="{{crate.repository}}">{{crate.name}} {{crate.version}}</a>{{#unless @last}}, {{/unless}}{{/each}}
  </p>
  <pre>{{text}}</pre>
  {{/each}}
</body>
</html>
